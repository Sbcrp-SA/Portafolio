{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Python: Instalando uv...",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-c",
                "irm https://astral.sh/uv/install.ps1 | iex"
            ],
            "problemMatcher": []
        },
        {
            "label": "Abrir Portafolio",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "start ${workspaceFolder}/index.html"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}
